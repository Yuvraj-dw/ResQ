{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		},
		"allowJs": true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"lib": ["es2020", "dom"],
		"moduleResolution": "bundler",
		"noEmit": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"target": "esnext",
		"types": ["react-native", "node"]
	},
	"include": ["**/*.ts", "**/*.tsx", "src/**/*"],
	"exclude": [
		"node_modules",
		"babel.config.js",
		"metro.config.js",
		"jest.config.js"
	]
}
